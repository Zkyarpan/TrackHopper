# Environment variable placeholders — copy to .env.local and fill in values
# Get your TfL app_key from https://api-portal.tfl.gov.uk (subscribe to "Unified API")
TFL_APP_KEY=

# Get your Pollinations secret key from https://enter.pollinations.ai (use the sk_ key — server-side only)
POLLINATIONS_API_KEY=

# Supabase — create a free project at https://supabase.com (Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: protect the /api/keep-alive cron endpoint from external callers.
# Set the same value in Vercel → Settings → Environment Variables.
# Vercel automatically sends it as "Authorization: Bearer <value>" for cron jobs.
CRON_SECRET=
